<Project>
  <PropertyGroup>
    <KFAuthorizationDocsSource>$(MSBuildThisFileDirectory)docs</KFAuthorizationDocsSource>
    <KFAuthorizationDocsFolderName>KF.Web.Authorization</KFAuthorizationDocsFolderName>
    <KFAuthorizationDocsDestination Condition="'$(SolutionDir)' != ''">
      $(SolutionDir)docs\$(KFAuthorizationDocsFolderName)
    </KFAuthorizationDocsDestination>
  </PropertyGroup>

  <Target Name="KFAuthorizationCopyDocs" AfterTargets="Restore" Condition="'$(KFAuthorizationDocsDestination)' != '' and Exists('$(KFAuthorizationDocsSource)')">
    <ItemGroup>
      <_KFAuthorizationDoc Include="$(KFAuthorizationDocsSource)\**\*" />
    </ItemGroup>
    <MakeDir Directories="$(KFAuthorizationDocsDestination)" />
    <Copy SourceFiles="@(_KFAuthorizationDoc)"
          DestinationFiles="@(_KFAuthorizationDoc->'$(KFAuthorizationDocsDestination)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
